# NVIDIA NIM API configuration (for free gpt-oss-120b or other models)
# Get a key at https://build.nvidia.com/
NVIDIA_API_KEY=
NVIDIA_MODEL=openai/gpt-oss-120b

# Hugging Face Access Token (Optional: get a free token at https://huggingface.co/settings/tokens)
# Set this to enable higher rate limits and faster downloads for local embedding models
HF_TOKEN=


# Groq API Key (Sign up at https://console.groq.com/ to get a free key)
# Leave empty to automatically fall back to local Ollama
GROQ_API_KEY=

# Local Ollama configuration (for offline mode)
# Make sure Ollama is running on your machine (https://ollama.com/)
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
