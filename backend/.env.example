# Groq API Key (Sign up at https://console.groq.com/ to get a free key)
# Leave empty to automatically fall back to local Ollama
GROQ_API_KEY=

# Local Ollama configuration (for offline mode)
# Make sure Ollama is running on your machine (https://ollama.com/)
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
